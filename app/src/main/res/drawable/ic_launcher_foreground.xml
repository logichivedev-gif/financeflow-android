<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. Drop Shadow for the Main Hexagon -->
    <path
        android:fillColor="#3508121A"
        android:pathData="M 54,22.5 L 83.8,39.5 L 83.8,74.5 L 54,91.5 L 24.2,74.5 L 24.2,39.5 Z" />

    <!-- 2. Main Hexagon Outer Surface (Slate Blue-Grey Base) -->
    <path
        android:pathData="M 54,21 L 82.5,37.5 L 82.5,70.5 L 54,87 L 25.5,70.5 L 25.5,37.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="21"
                android:endX="54"
                android:endY="87"
                android:type="linear">
                <item android:color="#2D3D4E" android:offset="0.0" />
                <item android:color="#1D2732" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Hexagon Inner Border Stroke to give highlighted crisp edges -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,22 L 81.7,38 L 81.7,70 L 54,86 L 26.3,70 L 26.3,38 Z"
        android:strokeWidth="1.6"
        android:strokeColor="#4E657B" />

    <!-- 4. Group with Clip Path to restrict Growth Bars to the interior of the Hexagon -->
    <group>
        <clip-path android:pathData="M 54,22 L 81.3,37.8 L 81.3,70.2 L 54,86 L 26.7,70.2 L 26.7,37.8 Z" />

        <!-- 5. Ascending Growth Bars (Beautiful Slate Accent Bars in the Background) -->
        <!-- Bar 1 -->
        <path
            android:fillColor="#22FFFFFF"
            android:pathData="M 32,64 L 38,64 L 38,88 L 32,88 Z" />
        <!-- Bar 2 -->
        <path
            android:fillColor="#28FFFFFF"
            android:pathData="M 41,56 L 47,56 L 47,88 L 41,88 Z" />
        <!-- Bar 3 -->
        <path
            android:fillColor="#30FFFFFF"
            android:pathData="M 50,47 L 56,47 L 56,88 L 50,88 Z" />
        <!-- Bar 4 -->
        <path
            android:fillColor="#36FFFFFF"
            android:pathData="M 59,38 L 65,38 L 65,88 L 59,88 Z" />
        <!-- Bar 5 -->
        <path
            android:fillColor="#40FFFFFF"
            android:pathData="M 68,29 L 74,29 L 74,88 L 68,88 Z" />
    </group>

    <!-- 6. Stylized slanted Euro Symbol with drop-shadows and premium teal gradients -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-6">

        <!-- Subtle shadow under the Euro Sign -->
        <path
            android:fillColor="#95081119"
            android:pathData="M 64.5,41.5 C 59.5,33.5 54.5,33.5 47.5,33.5 C 35.5,33.5 29.5,42.5 29.5,54.5 C 29.5,65.5 35.5,74.5 47.5,74.5 C 54.5,74.5 59.5,74.5 64.5,66.5 L 59,61.5 C 55.5,65.5 52,65.5 48,65.5 C 41,65.5 38,60.5 38,54.5 C 38,48.5 41,42.5 48,42.5 C 52,42.5 55.5,42.5 59,46.5 Z" />
        <path
            android:fillColor="#95081119"
            android:pathData="M 22.5,46.8 L 43,46.8 L 43,51.8 L 22.5,51.8 Z" />
        <path
            android:fillColor="#95081119"
            android:pathData="M 22.5,53.8 L 41,53.8 L 41,58.8 L 22.5,58.8 Z" />

        <!-- High-Contrast Bright Teal Euro Symbol -->
        <!-- Curved body of the Euro Sign -->
        <path
            android:pathData="M 63,40 C 58,32 53,32 46,32 C 34,32 28,41 28,53 C 28,64 34,73 46,73 C 53,73 58,73 63,65 L 57.5,60 C 54,64 50.5,64 46.5,64 C 39.5,64 36.5,59 36.5,53 C 36.5,47 39.5,41 46.5,41 C 50.5,41 54,41 57.5,45 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="28"
                    android:startY="32"
                    android:endX="63"
                    android:endY="73"
                    android:type="linear">
                    <item android:color="#4CE1E1" android:offset="0.0" />
                    <item android:color="#148080" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Upper Horizontal Crossbar -->
        <path
            android:pathData="M 21,45 L 42,45 L 42,50 L 21,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="21"
                    android:startY="45"
                    android:endX="42"
                    android:endY="50"
                    android:type="linear">
                    <item android:color="#4CE1E1" android:offset="0.0" />
                    <item android:color="#148080" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Lower Horizontal Crossbar -->
        <path
            android:pathData="M 21,52 L 40,52 L 40,57 L 21,57 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="21"
                    android:startY="52"
                    android:endX="40"
                    android:endY="57"
                    android:type="linear">
                    <item android:color="#4CE1E1" android:offset="0.0" />
                    <item android:color="#148080" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>
    </group>

</vector>
